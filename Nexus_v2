<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Nexus v2 — Intelligence-First ATS/CRM</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;600;700;800;900&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');

:root {
  --bg:#070910;
  --s1:#0d0f17;
  --s2:#131620;
  --s3:#1a1e2e;
  --border:#1f2438;
  --border2:#252c42;
  --a1:#4f7cff;
  --a2:#00d4a8;
  --a3:#ff6b35;
  --a4:#b06aff;
  --warn:#f5a623;
  --danger:#ff4560;
  --text:#dde2f5;
  --muted:#5a6385;
  --muted2:#8892b0;
  --r:10px;
  --r2:14px;
  --sw:240px;
  --hh:56px;
  --font:'Instrument Sans',sans-serif;
  --display:'Cabinet Grotesk',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;display:flex;overflow:hidden}
/* ── noise overlay ── */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:.4}

/* ═══ SIDEBAR ═══ */
.sidebar{width:var(--sw);min-height:100vh;background:var(--s1);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;left:0;bottom:0;z-index:100;overflow-y:auto;scrollbar-width:none}
.sidebar::-webkit-scrollbar{display:none}
.logo{padding:18px 16px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.logo-mark{width:32px;height:32px;background:linear-gradient(135deg,var(--a1),var(--a2));border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:var(--display);font-weight:900;font-size:15px;color:#fff;flex-shrink:0}
.logo-text{font-family:var(--display);font-weight:800;font-size:17px;letter-spacing:-.3px}
.logo-text em{color:var(--a1);font-style:normal}
.logo-badge{margin-left:auto;background:rgba(79,124,255,.15);border:1px solid rgba(79,124,255,.25);color:var(--a1);font-size:9px;font-weight:700;border-radius:20px;padding:2px 7px;letter-spacing:.5px}
nav{padding:10px 8px;flex:1}
.nav-sec{margin-bottom:18px}
.nav-lbl{font-size:9.5px;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:var(--muted);padding:5px 10px 3px}
.ni{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:500;color:var(--muted2);transition:all .15s;position:relative;user-select:none;white-space:nowrap}
.ni:hover{background:var(--s2);color:var(--text)}
.ni.active{background:rgba(79,124,255,.12);color:var(--a1)}
.ni.active::before{content:'';position:absolute;left:0;top:25%;bottom:25%;width:2.5px;background:var(--a1);border-radius:4px}
.ni-ic{width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.ni-badge{margin-left:auto;background:var(--a1);color:#fff;font-size:9px;font-weight:800;border-radius:20px;padding:1px 6px}
.ni-badge.r{background:var(--danger)}
.ni-badge.y{background:var(--warn);color:#000}
.ni-badge.g{background:var(--a2);color:#000}
.sidebar-footer{padding:12px 12px 16px;border-top:1px solid var(--border);flex-shrink:0}
.user-row{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:var(--s2);cursor:pointer;transition:background .15s}
.user-row:hover{background:var(--s3)}
.av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.user-info{flex:1;min-width:0}
.user-name{font-size:12.5px;font-weight:600;overflow:hidden;text-overflow:ellipsis}
.user-role{font-size:10.5px;color:var(--muted)}
.online-dot{width:7px;height:7px;border-radius:50%;background:var(--a2);flex-shrink:0}

/* ═══ MAIN ═══ */
.main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;min-height:100vh;overflow:hidden}
.topbar{height:var(--hh);background:var(--s1);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 22px;gap:14px;position:sticky;top:0;z-index:50;flex-shrink:0}
.page-title{font-family:var(--display);font-size:17px;font-weight:800;flex:1;letter-spacing:-.2px}
.topbar-actions{display:flex;gap:8px;align-items:center}
.search-wrap{display:flex;align-items:center;gap:7px;background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:6px 11px;width:220px;transition:border-color .15s}
.search-wrap:focus-within{border-color:var(--a1)}
.search-wrap input{border:none;background:transparent;font-family:var(--font);font-size:12.5px;color:var(--text);outline:none;flex:1}
.search-wrap input::placeholder{color:var(--muted)}
.icon-btn{width:30px;height:30px;border-radius:7px;background:var(--s2);border:1px solid var(--border);color:var(--muted2);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;position:relative}
.icon-btn:hover{border-color:var(--a1);color:var(--a1)}
.notif-dot{position:absolute;top:-2px;right:-2px;width:8px;height:8px;border-radius:50%;background:var(--danger);border:1.5px solid var(--s1)}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 15px;border-radius:8px;font-family:var(--font);font-size:12.5px;font-weight:600;cursor:pointer;border:none;transition:all .15s;white-space:nowrap}
.btn-p{background:linear-gradient(135deg,var(--a1),#2f5ce8);color:#fff;box-shadow:0 2px 12px rgba(79,124,255,.3)}
.btn-p:hover{box-shadow:0 4px 20px rgba(79,124,255,.45);transform:translateY(-1px)}
.btn-g{background:var(--s2);color:var(--text);border:1px solid var(--border)}
.btn-g:hover{border-color:var(--a1);color:var(--a1)}
.btn-sm{padding:5px 11px;font-size:12px}
.btn-xs{padding:3px 9px;font-size:11px}
.btn-danger{background:rgba(255,69,96,.12);color:var(--danger);border:1px solid rgba(255,69,96,.2)}

/* ═══ CONTENT ═══ */
.content{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.content::-webkit-scrollbar{width:5px}
.content::-webkit-scrollbar-thumb{background:var(--border);border-radius:5px}
.page{display:none;padding:22px}
.page.active{display:block;animation:fadeIn .2s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

/* ═══ CARDS ═══ */
.card{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);overflow:hidden}
.card:hover{border-color:var(--border2)}
.ch{display:flex;align-items:center;gap:10px;padding:14px 18px;border-bottom:1px solid var(--border)}
.ch-title{font-family:var(--display);font-size:13.5px;font-weight:700;flex:1}
.cb{padding:14px 18px}

/* ═══ STAT CARDS ═══ */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.scard{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:16px 18px;position:relative;overflow:hidden;transition:border-color .2s,transform .15s}
.scard:hover{border-color:var(--border2);transform:translateY(-1px)}
.scard::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.scard.b::after{background:linear-gradient(90deg,var(--a1),#7fa8ff)}
.scard.g::after{background:linear-gradient(90deg,var(--a2),#00ffcc)}
.scard.o::after{background:linear-gradient(90deg,var(--a3),#ffb347)}
.scard.p::after{background:linear-gradient(90deg,var(--a4),#e040fb)}
.scard.r::after{background:linear-gradient(90deg,var(--danger),#ff8a65)}
.s-lbl{font-size:11px;color:var(--muted);font-weight:600;margin-bottom:6px;letter-spacing:.3px}
.s-val{font-family:var(--display);font-size:26px;font-weight:800;line-height:1;margin-bottom:5px;letter-spacing:-.5px}
.s-sub{font-size:11px;color:var(--muted)}
.up{color:var(--a2)}.down{color:var(--danger)}
.scard .bg-icon{position:absolute;right:-4px;bottom:-8px;font-size:52px;opacity:.04}

/* ═══ TAGS & PILLS ═══ */
.tag{display:inline-flex;align-items:center;font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;letter-spacing:.2px;gap:3px}
.t-tech{background:rgba(79,124,255,.14);color:#8ab0ff}
.t-type{background:rgba(0,212,168,.12);color:var(--a2)}
.t-hot{background:rgba(245,166,35,.12);color:var(--warn)}
.t-urg{background:rgba(255,69,96,.12);color:var(--danger)}
.t-p{background:rgba(176,106,255,.13);color:var(--a4)}
.t-new{background:rgba(79,124,255,.1);color:var(--a1)}
.pill{display:inline-flex;align-items:center;gap:4px;font-size:10.5px;font-weight:700;padding:3px 10px;border-radius:20px}
.pill::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;opacity:.7}
.p-active{background:rgba(0,212,168,.1);color:var(--a2)}
.p-prospect{background:rgba(79,124,255,.1);color:#8ab0ff}
.p-screen{background:rgba(79,124,255,.12);color:#8ab0ff}
.p-interview{background:rgba(245,166,35,.1);color:var(--warn)}
.p-offer{background:rgba(0,212,168,.1);color:var(--a2)}
.p-placed{background:rgba(176,106,255,.12);color:var(--a4)}
.p-onhold{background:rgba(255,69,96,.1);color:var(--danger)}
.p-closed{background:rgba(90,99,133,.15);color:var(--muted)}
.p-won{background:rgba(0,212,168,.1);color:var(--a2)}
.p-lost{background:rgba(255,69,96,.1);color:var(--danger)}
.p-neg{background:rgba(245,166,35,.1);color:var(--warn)}
.p-lead{background:rgba(176,106,255,.1);color:var(--a4)}

/* ═══ AI SCORE BADGE ═══ */
.ai-score{display:inline-flex;align-items:center;gap:5px;background:rgba(0,212,168,.1);border:1px solid rgba(0,212,168,.2);border-radius:20px;padding:2px 9px;font-size:11px;font-weight:700;color:var(--a2)}
.ai-score.high{background:rgba(0,212,168,.12);border-color:rgba(0,212,168,.25);color:var(--a2)}
.ai-score.med{background:rgba(245,166,35,.1);border-color:rgba(245,166,35,.2);color:var(--warn)}
.ai-score.low{background:rgba(255,69,96,.08);border-color:rgba(255,69,96,.15);color:var(--danger)}
.score-ring{width:36px;height:36px;position:relative;flex-shrink:0}
.score-ring svg{width:100%;height:100%;transform:rotate(-90deg)}
.score-ring .score-val{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;font-family:var(--display)}

/* ═══ TABLE ═══ */
table{width:100%;border-collapse:collapse;font-size:12.5px}
thead th{text-align:left;padding:9px 14px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap;background:var(--s1)}
tbody tr{border-bottom:1px solid var(--border);transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:rgba(255,255,255,.018)}
td{padding:11px 14px;vertical-align:middle}
.td-name{font-weight:600;font-size:13px}
.td-m{color:var(--muted);font-size:11.5px}
.td-a{color:var(--a1);font-weight:600}
.td-g{color:var(--a2);font-weight:600}

/* ═══ KANBAN ═══ */
.kb-wrap{display:flex;gap:14px;overflow-x:auto;padding-bottom:14px;align-items:flex-start}
.kb-wrap::-webkit-scrollbar{height:5px}
.kb-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:5px}
.kb-col{min-width:262px;width:262px;background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);display:flex;flex-direction:column;max-height:calc(100vh - 170px);transition:border-color .15s}
.kb-col.drag-over{border-color:var(--a1);background:rgba(79,124,255,.03)}
.col-hd{display:flex;align-items:center;gap:7px;padding:12px 13px 10px;border-bottom:1px solid var(--border);position:sticky;top:0;background:inherit;border-radius:var(--r2) var(--r2) 0 0;flex-shrink:0}
.col-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.col-nm{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;flex:1}
.col-ct{background:var(--s2);border-radius:20px;font-size:10px;font-weight:800;padding:1px 7px;color:var(--muted)}
.col-cards{flex:1;overflow-y:auto;padding:8px 9px;display:flex;flex-direction:column;gap:7px;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.col-cards::-webkit-scrollbar{width:3px}
.k-card{background:var(--s2);border:1px solid var(--border);border-radius:9px;padding:11px 12px;cursor:grab;transition:border-color .15s,transform .1s,box-shadow .15s;user-select:none}
.k-card:hover{border-color:var(--a1);box-shadow:0 4px 18px rgba(79,124,255,.1);transform:translateY(-1px)}
.k-card.dragging{opacity:.45;transform:scale(.96);cursor:grabbing}
.kc-top{display:flex;align-items:flex-start;gap:8px;margin-bottom:7px}
.kc-av{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;flex-shrink:0;color:#fff}
.kc-name{font-size:12.5px;font-weight:700;line-height:1.3}
.kc-sub{font-size:10.5px;color:var(--muted)}
.kc-tags{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:7px}
.kc-bot{display:flex;align-items:center;justify-content:space-between}
.kc-rate{font-size:10.5px;color:var(--a2);font-weight:700}
.kc-day{font-size:10px;color:var(--muted)}
.kc-ai{display:flex;align-items:center;gap:4px;font-size:10px;font-weight:700;color:var(--a2);margin-top:5px;padding-top:5px;border-top:1px solid var(--border)}
.kc-ai span{color:var(--muted)}
.add-col{min-width:46px;width:46px;height:46px;border:2px dashed var(--border);border-radius:var(--r2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:20px;color:var(--muted);transition:all .15s;flex-shrink:0}
.add-col:hover{border-color:var(--a1);color:var(--a1)}

/* ═══ DETAIL PANEL ═══ */
.panel{position:fixed;top:0;right:-540px;bottom:0;width:520px;background:var(--s1);border-left:1px solid var(--border);z-index:200;transition:right .25s cubic-bezier(.4,0,.2,1);overflow-y:auto;display:flex;flex-direction:column}
.panel.open{right:0}
.panel-hd{padding:18px 22px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;position:sticky;top:0;background:var(--s1);z-index:10;flex-shrink:0}
.panel-title{font-family:var(--display);font-size:15px;font-weight:800;flex:1;letter-spacing:-.2px}
.close-btn{width:28px;height:28px;border-radius:7px;background:var(--s2);border:none;color:var(--muted);cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.close-btn:hover{background:var(--s3);color:var(--text)}
.panel-body{padding:18px 22px;flex:1}
.panel-tabs{display:flex;gap:2px;margin-bottom:18px;background:var(--s2);border-radius:9px;padding:3px}
.pt{padding:6px 14px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;color:var(--muted);border:none;background:transparent;font-family:var(--font);transition:all .15s}
.pt.active{background:var(--a1);color:#fff}
.panel-section{display:none}.panel-section.active{display:block}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px}
.ii{}.ii-l{font-size:10px;color:var(--muted);font-weight:600;margin-bottom:2px;letter-spacing:.3px}.ii-v{font-size:12.5px;font-weight:500}
.divider{height:1px;background:var(--border);margin:16px 0}
.s-title{font-family:var(--display);font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.9px;margin-bottom:10px}
/* Timeline */
.tl{display:flex;flex-direction:column}
.tli{display:flex;gap:11px;padding-bottom:14px;position:relative}
.tli::before{content:'';position:absolute;left:6px;top:18px;bottom:0;width:1px;background:var(--border)}
.tli:last-child::before{display:none}
.tl-dot{width:14px;height:14px;border-radius:50%;background:var(--s2);border:2px solid var(--a1);flex-shrink:0;margin-top:2px;z-index:1}
.tl-dot.g{border-color:var(--a2)}.tl-dot.y{border-color:var(--warn)}.tl-dot.r{border-color:var(--danger)}.tl-dot.p{border-color:var(--a4)}
.tl-c{flex:1}
.tl-act{font-size:12.5px;font-weight:500;line-height:1.4}
.tl-m{font-size:10.5px;color:var(--muted);margin-top:2px}
/* AI Match Ring */
.ai-ring-wrap{display:flex;align-items:center;gap:18px;padding:16px;background:var(--s2);border-radius:10px;margin-bottom:16px;border:1px solid var(--border)}
.ai-ring{position:relative;width:72px;height:72px;flex-shrink:0}
.ai-ring svg{width:100%;height:100%;transform:rotate(-90deg)}
.ai-ring .center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:var(--display)}
.ai-ring .center .pct{font-size:19px;font-weight:900}
.ai-ring .center .lbl{font-size:8px;color:var(--muted);font-weight:600}
.match-reasons{display:flex;flex-direction:column;gap:5px;flex:1}
.mr{display:flex;align-items:center;gap:6px;font-size:11px}
.mr-bar{flex:1;height:4px;background:var(--s3);border-radius:4px;overflow:hidden}
.mr-fill{height:100%;border-radius:4px;background:var(--a2);transition:width .4s ease}
.mr-fill.med{background:var(--warn)}
.mr-fill.low{background:var(--danger)}
.mr-lbl{width:70px;color:var(--muted);font-size:10px}
.mr-val{width:26px;text-align:right;font-weight:700;font-size:10px;color:var(--text)}

/* ═══ MODALS ═══ */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(6px);z-index:999;align-items:center;justify-content:center;padding:20px}
.overlay.open{display:flex}
.modal{background:var(--s1);border:1px solid var(--border2);border-radius:var(--r2);width:580px;max-width:100%;max-height:90vh;overflow-y:auto;animation:popIn .2s cubic-bezier(.34,1.4,.64,1)}
@keyframes popIn{from{transform:scale(.93);opacity:0}to{transform:scale(1);opacity:1}}
.m-hd{display:flex;align-items:center;padding:18px 22px 14px;border-bottom:1px solid var(--border);gap:12px;position:sticky;top:0;background:var(--s1);z-index:5}
.m-title{font-family:var(--display);font-size:15px;font-weight:800;flex:1;letter-spacing:-.2px}
.m-body{padding:18px 22px}
.m-foot{display:flex;justify-content:flex-end;gap:9px;padding:12px 22px 18px;border-top:1px solid var(--border)}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.fr.full{grid-template-columns:1fr}
.fg{display:flex;flex-direction:column;gap:4px}
.fl{font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.2px}
.fi{background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:8px 11px;font-family:var(--font);font-size:12.5px;color:var(--text);outline:none;transition:border-color .15s;width:100%}
.fi:focus{border-color:var(--a1)}
select.fi{cursor:pointer}
textarea.fi{resize:vertical;min-height:72px}
.fi::placeholder{color:var(--muted)}

/* ═══ TABS ═══ */
.tabs{display:flex;gap:2px;background:var(--s1);border-radius:9px;padding:3px;width:fit-content;border:1px solid var(--border)}
.tab{padding:6px 15px;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer;color:var(--muted);border:none;background:transparent;font-family:var(--font);transition:all .15s}
.tab.active{background:var(--a1);color:#fff}

/* ═══ ANALYTICS ═══ */
.analytics-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.bar-chart{display:flex;align-items:flex-end;gap:6px;height:110px;padding:0 4px}
.bg{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px}
.b{width:100%;border-radius:4px 4px 0 0;background:var(--a1);min-height:3px;transition:opacity .2s,height .4s ease}
.b:hover{opacity:.75}
.b.g{background:var(--a2)}.b.o{background:var(--a3)}.b.p{background:var(--a4)}
.b-l{font-size:9.5px;color:var(--muted)}
.b-v{font-size:9.5px;font-weight:700;color:var(--text)}
.funnel-row{display:flex;align-items:center;gap:9px;margin-bottom:7px}
.f-l{font-size:11px;color:var(--muted);width:95px;flex-shrink:0}
.f-bar{height:20px;border-radius:4px;display:flex;align-items:center;padding:0 7px;font-size:10.5px;font-weight:700;color:#fff;transition:width .6s ease;min-width:28px}
.f-n{font-size:11px;font-weight:700;color:var(--text);width:28px;text-align:right}
.donut-wrap{display:flex;align-items:center;gap:18px}
.donut{width:90px;height:90px;position:relative;flex-shrink:0}
.donut svg{width:100%;height:100%;transform:rotate(-90deg)}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:var(--display)}
.legend{display:flex;flex-direction:column;gap:7px}
.li2{display:flex;align-items:center;gap:7px;font-size:11px}
.ld{width:7px;height:7px;border-radius:50%;flex-shrink:0}
/* Recruiter Perf Table */
.rec-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border)}
.rec-row:last-child{border-bottom:none}
.rec-rank{font-family:var(--display);font-size:13px;font-weight:800;width:20px;color:var(--muted)}
.rec-info{flex:1}
.rec-name{font-size:12.5px;font-weight:600}
.rec-stat{font-size:10.5px;color:var(--muted)}
.rec-bar-wrap{width:90px;height:5px;background:var(--s2);border-radius:5px;overflow:hidden}
.rec-bar{height:100%;background:linear-gradient(90deg,var(--a1),var(--a2));border-radius:5px}
.rec-val{font-family:var(--display);font-size:14px;font-weight:800;width:30px;text-align:right;color:var(--a1)}

/* ═══ JOB CARDS ═══ */
.jg{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:14px}
.jc{background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:16px 18px;transition:border-color .15s,box-shadow .15s;cursor:pointer}
.jc:hover{border-color:var(--a1);box-shadow:0 6px 22px rgba(79,124,255,.09)}
.jc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.jc-title{font-family:var(--display);font-size:14px;font-weight:800;line-height:1.3}
.jc-client{font-size:11px;color:var(--muted);margin-top:2px}
.jc-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.jc-bar{margin-top:8px}
.jc-prog{height:3px;background:var(--s2);border-radius:3px;overflow:hidden;margin-top:3px}
.jc-fill{height:100%;background:linear-gradient(90deg,var(--a1),var(--a2));border-radius:3px}
.jc-meta{display:flex;gap:10px;padding-top:10px;border-top:1px solid var(--border);flex-wrap:wrap}
.jc-mi{font-size:10.5px;color:var(--muted);display:flex;align-items:center;gap:3px}
.jc-mi strong{color:var(--text);font-weight:600}

/* ═══ COMMS / INBOX ═══ */
.inbox-layout{display:grid;grid-template-columns:280px 1fr;gap:0;height:calc(100vh - 130px);overflow:hidden;border:1px solid var(--border);border-radius:var(--r2)}
.inbox-list{border-right:1px solid var(--border);overflow-y:auto;background:var(--s1)}
.inbox-list::-webkit-scrollbar{width:3px}
.inbox-list::-webkit-scrollbar-thumb{background:var(--border)}
.inbox-hd{padding:12px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.conv-item{padding:11px 14px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .12s}
.conv-item:hover{background:var(--s2)}
.conv-item.active{background:rgba(79,124,255,.07);border-left:2px solid var(--a1)}
.conv-name{font-size:12.5px;font-weight:600;margin-bottom:2px;display:flex;align-items:center;gap:6px}
.conv-preview{font-size:11px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.conv-time{font-size:10px;color:var(--muted);margin-left:auto;flex-shrink:0}
.unread-dot{width:7px;height:7px;border-radius:50%;background:var(--a1);flex-shrink:0}
.chat-area{display:flex;flex-direction:column;background:var(--bg)}
.chat-hd{padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:11px;background:var(--s1);flex-shrink:0}
.chat-msgs{flex:1;overflow-y:auto;padding:16px 18px;display:flex;flex-direction:column;gap:10px}
.chat-msgs::-webkit-scrollbar{width:3px}
.msg{display:flex;flex-direction:column;gap:3px;max-width:75%}
.msg.out{align-self:flex-end;align-items:flex-end}
.msg.in{align-self:flex-start;align-items:flex-start}
.msg-bubble{padding:9px 13px;border-radius:10px;font-size:12.5px;line-height:1.5}
.msg.out .msg-bubble{background:var(--a1);color:#fff;border-radius:10px 10px 3px 10px}
.msg.in .msg-bubble{background:var(--s2);color:var(--text);border:1px solid var(--border);border-radius:10px 10px 10px 3px}
.msg-time{font-size:10px;color:var(--muted);padding:0 4px}
.chat-input-wrap{padding:12px 16px;border-top:1px solid var(--border);background:var(--s1);display:flex;gap:8px;flex-shrink:0;align-items:flex-end}
.chat-input{flex:1;background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:8px 12px;font-family:var(--font);font-size:12.5px;color:var(--text);outline:none;resize:none;min-height:36px;max-height:80px;transition:border-color .15s}
.chat-input:focus{border-color:var(--a1)}
.chat-actions{display:flex;gap:6px;padding:0 18px 10px;background:var(--s1);flex-shrink:0}

/* ═══ WORKFLOW ═══ */
.wf-step{display:flex;gap:12px;padding:14px;border:1px solid var(--border);border-radius:10px;margin-bottom:8px;cursor:pointer;transition:border-color .15s}
.wf-step:hover{border-color:var(--a1)}
.wf-num{width:26px;height:26px;border-radius:50%;background:var(--a1);color:#fff;font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--display)}
.wf-content{flex:1}
.wf-title{font-size:13px;font-weight:700;margin-bottom:3px}
.wf-desc{font-size:11.5px;color:var(--muted);line-height:1.5}
.wf-badge{margin-left:auto;align-self:flex-start}
.wf-trigger{display:flex;align-items:center;gap:8px;padding:9px 12px;background:var(--s2);border:1px solid var(--border);border-radius:8px;margin-bottom:6px;font-size:12px;cursor:pointer;transition:border-color .15s}
.wf-trigger:hover{border-color:var(--a1)}
.wf-trigger-ic{font-size:16px;width:24px;text-align:center;flex-shrink:0}
.wf-toggle{width:34px;height:18px;border-radius:18px;background:var(--border);position:relative;cursor:pointer;transition:background .2s;flex-shrink:0;margin-left:auto}
.wf-toggle.on{background:var(--a2)}
.wf-toggle::after{content:'';position:absolute;top:2px;left:2px;width:14px;height:14px;border-radius:50%;background:#fff;transition:transform .2s}
.wf-toggle.on::after{transform:translateX(16px)}

/* ═══ RBAC ═══ */
.role-card{border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:10px;transition:border-color .15s}
.role-card:hover{border-color:var(--border2)}
.role-hd{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.role-badge{padding:2px 10px;border-radius:20px;font-size:10.5px;font-weight:700}
.perm-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.perm{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--muted2)}
.perm.on{color:var(--a2)}.perm.off{color:var(--muted);text-decoration:line-through;opacity:.5}
.perm-ic{font-size:12px}

/* ═══ MISC ═══ */
.flex{display:flex;align-items:center;gap:8px}
.ml-a{margin-left:auto}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.mb-4{margin-bottom:4px}
.mb-8{margin-bottom:8px}
.mb-14{margin-bottom:14px}
.mb-20{margin-bottom:20px}
.text-a1{color:var(--a1)}.text-a2{color:var(--a2)}.text-a3{color:var(--a3)}.text-a4{color:var(--a4)}.text-m{color:var(--muted)}.text-warn{color:var(--warn)}.text-r{color:var(--danger)}
.fw7{font-weight:700}
/* Toast */
.toast-c{position:fixed;bottom:22px;right:22px;display:flex;flex-direction:column;gap:7px;z-index:9999}
.toast{background:var(--s1);border:1px solid var(--border2);border-radius:10px;padding:11px 15px;font-size:12.5px;display:flex;align-items:center;gap:10px;animation:slideIn .2s ease;min-width:250px;box-shadow:0 8px 30px rgba(0,0,0,.45)}
@keyframes slideIn{from{transform:translateX(28px);opacity:0}to{transform:translateX(0);opacity:1}}
.toast.s{border-color:rgba(0,212,168,.3)}
.toast.e{border-color:rgba(255,69,96,.3)}
.toast.i{border-color:rgba(79,124,255,.3)}
.toast-ic{font-size:15px;flex-shrink:0}
/* Backdrop */
#backdrop{display:none;position:fixed;inset:0;z-index:199}
/* Progress bar */
.prog-wrap{height:4px;background:var(--s2);border-radius:4px;overflow:hidden;margin-top:4px}
.prog-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--a1),var(--a2))}
/* Aging badge */
.age-badge{font-size:10px;font-weight:700;padding:1px 7px;border-radius:20px}
.age-ok{background:rgba(0,212,168,.1);color:var(--a2)}
.age-warn{background:rgba(245,166,35,.12);color:var(--warn)}
.age-danger{background:rgba(255,69,96,.1);color:var(--danger)}
/* SLA */
.sla-bar{height:6px;border-radius:6px;overflow:hidden;background:var(--s2);margin-top:3px}
.sla-fill{height:100%;border-radius:6px}
/* Notif panel */
.notif-panel{position:absolute;top:calc(100% + 6px);right:0;width:320px;background:var(--s1);border:1px solid var(--border2);border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,.5);z-index:300;display:none}
.notif-panel.open{display:block}
.notif-hd{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center}
.ni-item{padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .12s;display:flex;gap:9px;align-items:flex-start}
.ni-item:hover{background:var(--s2)}
.ni-item:last-child{border-bottom:none}
.ni-ic2{font-size:15px;flex-shrink:0;margin-top:1px}
.ni-text{font-size:11.5px;line-height:1.4}
.ni-t{font-size:10px;color:var(--muted);margin-top:2px}

/* scrollbar global */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:5px}
</style>
</head>
