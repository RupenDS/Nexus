      <div class="fr"><div class="fg"><label class="fl">Company</label><select class="fi"><option>TechCorp India</option><option>HCL Technologies</option><option>Wipro Enterprise</option><option>FinEdge Solutions</option></select></div><div class="fg"><label class="fl">Title</label><input class="fi" placeholder="VP Talent"/></div></div>
    </div>
    <div class="m-foot"><button class="btn btn-g" onclick="closeModal('addContact')">Cancel</button><button class="btn btn-p" onclick="saveContact()">Save Contact</button></div>
  </div>
</div>

<!-- Generate Offer -->
<div class="overlay" id="genOffer">
  <div class="modal">
    <div class="m-hd"><div class="m-title">Generate Offer Letter</div><button class="close-btn" onclick="closeModal('genOffer')">✕</button></div>
    <div class="m-body">
      <div class="fr"><div class="fg"><label class="fl">Candidate *</label><select class="fi"><option>Anita Roy</option><option>Arjun Mehta</option><option>Vijay Kumar</option></select></div><div class="fg"><label class="fl">Client *</label><select class="fi"><option>TCS Digital</option><option>TechCorp India</option><option>HCL Technologies</option></select></div></div>
      <div class="fr"><div class="fg"><label class="fl">Offered CTC (LPA)</label><input class="fi" placeholder="30"/></div><div class="fg"><label class="fl">Joining Date</label><input class="fi" type="date"/></div></div>
      <div class="fr"><div class="fg"><label class="fl">Role Title</label><input class="fi" placeholder="Full Stack Developer"/></div><div class="fg"><label class="fl">Offer Template</label><select class="fi"><option>Standard Full-time</option><option>Contract Engagement</option><option>C2H Template</option></select></div></div>
      <div class="fr full"><div class="fg"><label class="fl">Additional Terms / Notes</label><textarea class="fi" placeholder="Stock options, remote days, signing bonus…"></textarea></div></div>
    </div>
    <div class="m-foot"><button class="btn btn-g" onclick="closeModal('genOffer')">Cancel</button><button class="btn btn-p" onclick="closeModal('genOffer');showToast('Offer letter generated and sent via email + DocuSign','s')">Generate & Send</button></div>
  </div>
</div>

<!-- Toast container -->
<div class="toast-c" id="toastC"></div>
<div id="backdrop" onclick="closeAllPanels()"></div>

<script>
// ── Navigation ──
const pageTitles = {dashboard:'Dashboard',pipeline:'ATS / Deal Pipeline',candidates:'Candidates',jobs:'Job Orders',ai:'AI Matching Engine',clients:'Clients',deals:'Deals',contacts:'Contacts',comms:'Communications',offers:'Offer & Documents',workflows:'Workflows & Automations',analytics:'Analytics',recruiter:'Recruiter KPIs',rbac:'Roles & Access',audit:'Audit Log'};
function nav(p,el){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.ni').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  el.classList.add('active');
  document.getElementById('pageTitle').textContent=pageTitles[p]||p;
}

// ── Kanban Tab ──
function switchKB(t,btn){
  document.querySelectorAll('.tabs .tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('ats-kb').style.display=t==='ats'?'flex':'none';
  document.getElementById('deals-kb').style.display=t==='deals'?'flex':'none';
}

// ── Drag & Drop ──
let drag=null;
function dst(e,c){drag=c;c.classList.add('dragging');e.dataTransfer.effectAllowed='move'}
function dov(e,col){e.preventDefault();document.querySelectorAll('.kb-col').forEach(c=>c.classList.remove('drag-over'));col.classList.add('drag-over')}
function ddr(e,col){e.preventDefault();if(drag){col.querySelector('.col-cards').appendChild(drag);drag.classList.remove('dragging');updateCounts();showToast('Stage updated ✓','s');drag=null}col.classList.remove('drag-over')}
document.addEventListener('dragend',()=>{if(drag)drag.classList.remove('dragging');document.querySelectorAll('.kb-col').forEach(c=>c.classList.remove('drag-over'))});
function updateCounts(){document.querySelectorAll('.kb-col').forEach(col=>{const cnt=col.querySelectorAll('.k-card').length;const ct=col.querySelector('.col-ct');if(ct)ct.textContent=cnt})}

// ── Modals ──
function openModal(id){document.getElementById(id).classList.add('open')}
function closeModal(id){document.getElementById(id).classList.remove('open')}
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open')}));

// ── Panels ──
function openCandPanel(c){document.getElementById('candPanel').classList.add('open');document.getElementById('backdrop').style.display='block'}
function openCandDetail(){document.getElementById('candPanel').classList.add('open');document.getElementById('backdrop').style.display='block'}
function openClientPanel(){document.getElementById('clientPanel').classList.add('open');document.getElementById('backdrop').style.display='block'}
function closePanel(id){document.getElementById(id).classList.remove('open');document.getElementById('backdrop').style.display='none'}
function closeAllPanels(){document.querySelectorAll('.panel').forEach(p=>p.classList.remove('open'));document.getElementById('backdrop').style.display='none'}

// ── Panel Tabs ──
function switchPT(btn,section){
  const panel=btn.closest('.panel-body')||btn.closest('.modal');
  const tabs=btn.closest('.panel-tabs').querySelectorAll('.pt');
  tabs.forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  const parent=btn.closest('.panel-body');
  parent.querySelectorAll('.panel-section').forEach(s=>s.classList.remove('active'));
  document.getElementById(section).classList.add('active');
}

// ── Save stubs ──
function saveCand(){closeModal('addCand');showToast('Candidate added & AI match running…','s')}
function saveJob(){closeModal('addJob');showToast('Job order created · AI matching started','s')}
function saveClient(){closeModal('addClient');showToast('Client added to CRM','s')}
function saveDeal(){closeModal('addDeal');showToast('Deal created in pipeline','s')}
function saveContact(){closeModal('addContact');showToast('Contact saved','s')}

// ── Notifications ──
function toggleNotif(){const p=document.getElementById('notifPanel');p.classList.toggle('open')}
document.addEventListener('click',e=>{const btn=document.getElementById('notifBtn');const panel=document.getElementById('notifPanel');if(!btn.contains(e.target)&&!panel.contains(e.target))panel.classList.remove('open')});

// ── Workflow toggle ──
function toggleWF(el){el.classList.toggle('on');showToast(el.classList.contains('on')?'Workflow enabled':'Workflow disabled','s')}

// ── Converation select ──
function selectConv(el){document.querySelectorAll('.conv-item').forEach(c=>c.classList.remove('active'));el.classList.add('active');const dot=el.querySelector('.unread-dot');if(dot)dot.remove()}

// ── Toast ──
function showToast(msg,type='i'){
  const c=document.getElementById('toastC');
  const t=document.createElement('div');
  t.className=`toast ${type}`;
  const icons={'s':'<span style="color:var(--a2)">✓</span>','e':'<span style="color:var(--danger)">✕</span>','i':'<span style="color:var(--a1)">✦</span>'};
  t.innerHTML=`<span class="toast-ic">${icons[type]||icons.i}</span><span>${msg}</span>`;
  c.appendChild(t);
  setTimeout(()=>{t.style.cssText='opacity:0;transform:translateX(20px);transition:all .2s';setTimeout(()=>t.remove(),200)},3000);
}

// ── Keyboard ──
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){document.querySelectorAll('.overlay.open').forEach(o=>o.classList.remove('open'));closeAllPanels()}
  if((e.ctrlKey||e.metaKey)&&e.key==='k'){e.preventDefault();document.getElementById('searchInput').focus()}
});

// ── Init ──
setTimeout(()=>showToast('Welcome back, Rahul! 3 SLA alerts need attention.','i'),600);
setTimeout(()=>showToast('✦ AI: Vijay Kumar matches Cloud Architect role at 92%','s'),1800);
</script>
</body>
</html>

